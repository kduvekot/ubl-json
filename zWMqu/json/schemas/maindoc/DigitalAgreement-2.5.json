{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document used to support business parties agreeing on a set of digital processes, terms and conditions to ensure interoperability.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/DigitalAgreement-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "AgreementTypeCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/AgreementTypeCode"
    },
    "VersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/VersionID"
    },
    "PreviousVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/PreviousVersionID"
    },
    "RequiredResponseMessageLevelCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/RequiredResponseMessageLevelCode"
    },
    "GovernorParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ParticipantParty": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ParticipantPartyType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ParticipantPartyType"
          },
          "minItems": 1
        }
      ]
    },
    "AgreementCountry": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CountryType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CountryType"
          }
        }
      ]
    },
    "RequiredCertificationDocumentReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "DigitalAgreementTerms": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DigitalAgreementTermsType"
    },
    "DigitalProcess": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DigitalProcessType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DigitalProcessType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "IssueDate",
    "VersionID",
    "ParticipantParty",
    "DigitalProcess"
  ],
  "additionalProperties": false
}
