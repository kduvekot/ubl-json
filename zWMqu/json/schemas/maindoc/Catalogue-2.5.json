      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TradingTermsType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TradingTermsType"
          }
        }
      ]
    },
    "CatalogueLine": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CatalogueLineType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CatalogueLineType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "IssueDate",
    "ProviderParty",
    "ReceiverParty",
    "CatalogueLine"
  ],
  "additionalProperties": false
}
