{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document sent by a transport service provider to announce the availability of a transport service.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/TransportServiceDescription-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "ServiceName": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ServiceName"
    },
    "ResponseCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ResponseCode"
    },
    "SenderParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "TransportServiceDescriptionRequestDocumentReference": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
    },
    "TransportServiceProviderParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ServiceChargePaymentTerms": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PaymentTermsType"
    },
    "ValidityPeriod": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PeriodType"
    },
    "TransportationService": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TransportationServiceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TransportationServiceType"
          }
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID"
  ],
  "additionalProperties": false,
  "title": "Transport Service Description. Details"
}
