    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "TransactionDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/TransactionDate"
    },
    "TransactionTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/TransactionTime"
    },
    "PurchaseDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/PurchaseDate"
    },
    "PurchaseTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/PurchaseTime"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "DocumentCurrencyCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/DocumentCurrencyCode"
    },
    "PurchaseReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PurchaseReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PurchaseReferenceType"
