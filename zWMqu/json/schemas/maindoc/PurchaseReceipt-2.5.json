    "LegalMonetaryTotal": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/MonetaryTotalType"
    },
    "PurchaseReceiptLine": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PurchaseReceiptLineType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PurchaseReceiptLineType"
          },
          "minItems": 1
        }
      ]
    }
