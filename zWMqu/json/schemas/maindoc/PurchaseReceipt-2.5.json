      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/AllowanceChargeType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/AllowanceChargeType"
          }
        }
      ]
    },
    "TaxExchangeRate": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ExchangeRateType"
    },
    "PricingExchangeRate": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ExchangeRateType"
    },
    "TaxTotal": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TaxTotalType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TaxTotalType"
          }
        }
      ]
