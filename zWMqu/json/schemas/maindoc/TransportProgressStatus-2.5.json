{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document sent from a Transportation Network Manager to a Transport Service Provider giving the status of the whereabouts and schedule of the transport means involved in a transport service.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/TransportProgressStatus-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "StatusAvailableIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/StatusAvailableIndicator"
    },
    "SenderParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "SourceIssuerParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "TransportProgressStatusRequestDocumentReference": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
    },
    "TransportMeans": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TransportMeansType"
    },
    "TransportSchedule": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TransportScheduleType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/TransportScheduleType"
          }
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "IssueDate",
    "IssueTime",
    "TransportMeans"
  ],
  "additionalProperties": false,
  "title": "Transport Progress Status. Details"
}
