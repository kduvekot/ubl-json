{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:oasis:names:specification:ubl:schema:json:UnqualifiedDataTypes-2",
  "description": "UBL 2.5 Unqualified Data Types",
  "$defs": {
    "DateType": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "One calendar day according to the Gregorian calendar."
    },
    "TimeType": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})?$",
      "description": "A specific point in time recurring every day."
    },
    "IndicatorType": {
      "type": "boolean",
      "description": "A list whose elements are restricted to \"true\" and \"false\"."
    },
    "NumericType": {
      "type": "number",
      "description": "Numeric information that is assigned or is determined by calculation."
    },
    "PercentType": {
      "type": "number",
      "description": "Numeric information that is assigned or is determined by calculation."
    },
    "RateType": {
      "type": "number",
      "description": "A numeric expression of a rate."
    },
    "AmountType": {
      "type": "object",
      "properties": {
        "value": {
          "type": "number"
        },
        "currencyID": {
          "type": "string"
        },
        "currencyCodeListVersionID": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "currencyID"
      ],
      "additionalProperties": false,
      "description": "A number of monetary units specified in a given currency."
    },
    "BinaryObjectType": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "mimeCode": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "encodingCode": {
          "type": "string"
        },
        "characterSetCode": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "description": "A set of finite-length sequences of binary octets."
    },
    "MeasureType": {
      "type": "object",
      "properties": {
        "value": {
          "type": "number"
        },
        "unitCode": {
          "type": "string"
        },
        "unitCodeListVersionID": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "unitCode"
      ],
      "additionalProperties": false,
      "description": "A numeric measurement of something."
    },
    "CodeType": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "listID": {
              "type": "string"
            },
            "listAgencyID": {
              "type": "string"
            },
            "listAgencyName": {
              "type": "string"
            },
            "listName": {
              "type": "string"
            },
            "listVersionID": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "languageID": {
              "type": "string"
            },
            "listURI": {
              "type": "string"
            },
            "listSchemeURI": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      ],
      "description": "A character string (letters, figures, or symbols) from a controlled vocabulary or code list."
    },
    "IdentifierType": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "schemeID": {
              "type": "string"
            },
            "schemeName": {
              "type": "string"
            },
            "schemeAgencyID": {
              "type": "string"
            },
            "schemeAgencyName": {
              "type": "string"
            },
            "schemeVersionID": {
              "type": "string"
            },
            "schemeDataURI": {
              "type": "string"
            },
            "schemeURI": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      ],
      "description": "An identifier for an object."
    },
    "QuantityType": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "number"
            },
            "unitCode": {
              "type": "string"
            },
            "unitCodeListID": {
              "type": "string"
            },
            "unitCodeListAgencyID": {
              "type": "string"
            },
            "unitCodeListAgencyName": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      ],
      "description": "A counted number of non-monetary units."
    },
    "TextType": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "languageID": {
              "type": "string"
            },
            "languageLocaleID": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      ],
      "description": "A character string (including spaces and line breaks) the expression of a natural language."
    },
    "NameType": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "languageID": {
              "type": "string"
            },
            "languageLocaleID": {
              "type": "string"
            }
          },
          "required": [
            "value"
          ],
          "additionalProperties": false
        }
      ],
      "description": "A character string (including spaces and line breaks) the expression of a natural language."
    },
    "ContentType": {
      "type": "object",
      "description": "Extension content. Any structure is allowed."
    }
  }
}
