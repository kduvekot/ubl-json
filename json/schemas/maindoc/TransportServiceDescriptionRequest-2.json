{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/TransportServiceDescriptionRequest-2",
  "description": "A document requesting a Transport Service Description, sent from a party with a transport demand (transport user) to a party providing transport services (transport service provider).",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/TransportServiceDescriptionRequest-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/Note"
    },
    "ServiceInformationPreferenceCode": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ServiceInformationPreferenceCode"
    },
    "SenderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "TransportServiceProviderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "TransportationService": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportationServiceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportationServiceType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "$schema",
    "ID",
    "IssueDate",
    "IssueTime",
    "TransportationService"
  ],
  "additionalProperties": false
}
