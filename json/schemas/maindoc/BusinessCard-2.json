{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/BusinessCard-2",
  "description": "A document used to provide information about a business party and its business capabilities.",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/BusinessCard-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "VersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/VersionID"
    },
    "PreviousVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/PreviousVersionID"
    },
    "BriefDescription": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/BriefDescription"
    },
    "SenderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "BusinessParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "BrochureDocumentReference": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "AdditionalDocumentReference": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "BusinessCapability": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/CapabilityType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/CapabilityType"
          }
        }
      ]
    }
  },
  "required": [
    "$schema",
    "ID",
    "IssueDate",
    "BusinessParty"
  ],
  "additionalProperties": false
}
