{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/TenderReceipt-2",
  "description": "A document sent by a contracting party to an economic operator acknowledging receipt of a Tender.",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/TenderReceipt-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "ContractFolderID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ContractFolderID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "ContractName": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ContractName"
    },
    "Note": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/Note"
    },
    "RegisteredDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/RegisteredDate"
    },
    "RegisteredTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/RegisteredTime"
    },
    "TenderDocumentReference": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "SenderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    }
  },
  "required": [
    "$schema",
    "ContractFolderID",
    "IssueDate",
    "RegisteredDate",
    "RegisteredTime",
    "SenderParty",
    "ReceiverParty"
  ],
  "additionalProperties": false
}
