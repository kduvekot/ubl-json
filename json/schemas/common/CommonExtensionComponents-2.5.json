{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:oasis:names:specification:ubl:schema:json:CommonExtensionComponents-2",
  "description": "UBL 2.5 Common Extension Components",
  "$defs": {
    "UBLExtensionsType": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/UBLExtensionType"
      },
      "minItems": 1
    },
    "UBLExtensionType": {
      "type": "object",
      "description": "A single extension for private use.",
      "properties": {
        "ID": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ID"
        },
        "Name": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/Name"
        },
        "ExtensionAgencyID": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionAgencyID"
        },
        "ExtensionAgencyName": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionAgencyName"
        },
        "ExtensionVersionID": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionVersionID"
        },
        "ExtensionAgencyURI": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionAgencyURI"
        },
        "ExtensionURI": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionURI"
        },
        "ExtensionReasonCode": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionReasonCode"
        },
        "ExtensionReason": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:CommonBasicComponents-2#/$defs/ExtensionReason"
        },
        "ExtensionContent": {
          "$ref": "urn:oasis:names:specification:ubl:schema:json:UnqualifiedDataTypes-2#/$defs/ContentType"
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "title": "UBL Extension. Details",
      "required": [
        "ExtensionContent",
        "ExtensionURI"
      ]
    }
  }
}
