    },
    "CarrierAssignedID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CarrierAssignedID"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
