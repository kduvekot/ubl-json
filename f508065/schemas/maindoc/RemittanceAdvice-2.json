    "InvoicePeriod": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/PeriodType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/PeriodType"
          }
        }
      ]
