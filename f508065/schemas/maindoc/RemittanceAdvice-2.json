{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/RemittanceAdvice-2",
  "description": "A document that specifies details of an actual payment.",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/RemittanceAdvice-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/Note"
    },
    "DocumentCurrencyCode": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/DocumentCurrencyCode"
    },
    "TotalDebitAmount": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/TotalDebitAmount"
    },
    "TotalCreditAmount": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/TotalCreditAmount"
    },
    "TotalPaymentAmount": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/TotalPaymentAmount"
    },
    "PaymentOrderReference": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/PaymentOrderReference"
    },
    "PayerReference": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/PayerReference"
    },
    "InvoicingPartyReference": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/InvoicingPartyReference"
