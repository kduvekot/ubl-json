{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document used to describe the despatch or delivery of goods and services.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/DespatchAdvice-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "DocumentStatusCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/DocumentStatusCode"
    },
    "DespatchAdviceTypeCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/DespatchAdviceTypeCode"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "AccountingCostCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/AccountingCostCode"
    },
    "AccountingCost": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/AccountingCost"
    },
    "LineCountNumeric": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/LineCountNumeric"
    },
    "OrderReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/OrderReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/OrderReferenceType"
          }
        }
      ]
    },
    "ProjectReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ProjectReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ProjectReferenceType"
          }
        }
      ]
    },
    "AdditionalDocumentReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "DespatchSupplierParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SupplierPartyType"
    },
    "DeliveryCustomerParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CustomerPartyType"
    },
    "BuyerCustomerParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CustomerPartyType"
    },
    "SellerSupplierParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SupplierPartyType"
    },
    "OriginatorCustomerParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CustomerPartyType"
    },
    "BeneficiaryParty": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
          }
        }
      ]
    },
    "Shipment": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ShipmentType"
    },
    "DespatchLine": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DespatchLineType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DespatchLineType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "IssueDate",
    "DespatchSupplierParty",
    "DeliveryCustomerParty",
    "DespatchLine"
  ],
  "additionalProperties": false
}
