{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document listing the contents, cargo, passengers and crew of an airplane, a ship, a truck or a wagon.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/Manifest-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "ManifestTypeCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ManifestTypeCode"
    },
    "ManifestType": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ManifestType"
    },
    "Description": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Description"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "VersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/VersionID"
    },
    "AdValoremIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/AdValoremIndicator"
    },
    "DeclaredCarriageValueAmount": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/DeclaredCarriageValueAmount"
    },
    "SendingLogisticsOperatorParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "AuthorityParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ConsignorParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ConsigneeParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "CrewPerson": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PersonType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PersonType"
          }
        }
      ]
    },
    "PassengerPerson": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PersonType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PersonType"
          }
        }
      ]
    },
    "Shipment": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ShipmentType"
    },
    "DocumentReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "DocumentDistribution": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentDistributionType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentDistributionType"
          }
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "SendingLogisticsOperatorParty"
  ],
  "additionalProperties": false
}
