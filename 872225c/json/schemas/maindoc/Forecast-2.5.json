{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A document used to forecast sales or orders.",
  "type": "object",
  "properties": {
    "UBLEntity": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/Forecast-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "../common/CommonExtensionComponents-2.5.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/Note"
    },
    "VersionID": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/VersionID"
    },
    "BasedOnConsensusIndicator": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/BasedOnConsensusIndicator"
    },
    "ForecastPurposeCode": {
      "$ref": "../common/CommonBasicComponents-2.5.json#/$defs/ForecastPurposeCode"
    },
    "ForecastPeriod": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PeriodType"
    },
    "AdditionalDocumentReference": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/DocumentReferenceType"
          }
        }
      ]
    },
    "SenderParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/PartyType"
    },
    "BuyerCustomerParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/CustomerPartyType"
    },
    "SellerSupplierParty": {
      "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/SupplierPartyType"
    },
    "ForecastLine": {
      "oneOf": [
        {
          "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ForecastLineType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "../common/CommonAggregateComponents-2.5.json#/$defs/ForecastLineType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "UBLEntity",
    "ID",
    "IssueDate",
    "ForecastPurposeCode",
    "ForecastPeriod",
    "SenderParty",
    "ReceiverParty",
    "ForecastLine"
  ],
  "additionalProperties": false
}
