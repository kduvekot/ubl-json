{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/ApplicationResponse-2",
  "description": "A document to indicate the application's response to a transaction. This may be a business response initiated by a user or a technical response sent automatically by an application.",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/ApplicationResponse-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "ResponseDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ResponseDate"
    },
    "ResponseTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ResponseTime"
    },
    "Note": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/Note"
    },
    "VersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/VersionID"
    },
    "SenderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "DocumentResponse": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentResponseType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/DocumentResponseType"
          }
        }
      ]
    }
  },
  "required": [
    "$schema",
    "ID",
    "IssueDate",
    "SenderParty",
    "ReceiverParty"
  ],
  "additionalProperties": false
}
