{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.oasis-open.org/ubl/2/json/schemas/GoodsItemItinerary-2",
  "description": "A document providing details relating to a transport service, such as transport movement, identification of equipment and goods, subcontracted service providers, etc.",
  "type": "object",
  "properties": {
    "$schema": {
      "const": "https://docs.oasis-open.org/ubl/2/json/schemas/GoodsItemItinerary-2",
      "description": "The JSON Schema identifier for this document type."
    },
    "UBLExtensions": {
      "$ref": "common/CommonExtensionComponents-2.json#/$defs/UBLExtensionsType"
    },
    "Signature": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/SignatureType"
          }
        }
      ]
    },
    "UBLVersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UBLVersionID"
    },
    "CustomizationID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CustomizationID"
    },
    "ProfileID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileID"
    },
    "ProfileExecutionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ProfileExecutionID"
    },
    "ID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/ID"
    },
    "CopyIndicator": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/CopyIndicator"
    },
    "UUID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/UUID"
    },
    "IssueDate": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueDate"
    },
    "IssueTime": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/IssueTime"
    },
    "Note": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/Note"
    },
    "VersionID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/VersionID"
    },
    "TransportExecutionPlanReferenceID": {
      "$ref": "common/CommonBasicComponents-2.json#/$defs/TransportExecutionPlanReferenceID"
    },
    "SenderParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReceiverParty": {
      "$ref": "common/CommonAggregateComponents-2.json#/$defs/PartyType"
    },
    "ReferencedConsignment": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/ConsignmentType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/ConsignmentType"
          }
        }
      ]
    },
    "ReferencedTransportEquipment": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportEquipmentType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportEquipmentType"
          }
        }
      ]
    },
    "ReferencedPackage": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/PackageType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/PackageType"
          }
        }
      ]
    },
    "ReferencedGoodsItem": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/GoodsItemType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/GoodsItemType"
          }
        }
      ]
    },
    "TransportationSegment": {
      "oneOf": [
        {
          "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportationSegmentType"
        },
        {
          "type": "array",
          "items": {
            "$ref": "common/CommonAggregateComponents-2.json#/$defs/TransportationSegmentType"
          },
          "minItems": 1
        }
      ]
    }
  },
  "required": [
    "$schema",
    "ID",
    "IssueDate",
    "IssueTime",
    "VersionID",
    "TransportExecutionPlanReferenceID",
    "TransportationSegment"
  ],
  "additionalProperties": false
}
